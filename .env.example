# Copy this file to .env and fill in your own values.
# Never commit your real .env file - it's already excluded in .gitignore.

# Get these by building your own agent on airia.ai (use docs/soc_playbook.txt
# as the agent's instructions), publishing it, and copying its execution
# endpoint + API key.
AIRIA_API_URL=https://api.airia.ai/v2/PipelineExecution/<your-pipeline-id>
AIRIA_API_KEY=your_airia_api_key_here

# Capture settings
CAPTURE_INTERFACE=eth0
CAPTURE_DURATION=100
PACKET_THRESHOLD=40

# Victim machine metadata (used in the alert payload)
DESTINATION_HOST=Internal-server
DESTINATION_IP=192.168.0.206
